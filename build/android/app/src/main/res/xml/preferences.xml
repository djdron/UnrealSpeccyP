<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:title="@string/preferences">
    <PreferenceCategory android:title="@string/pref_control">
        <ListPreference android:entryValues="@array/joystick_values" android:entries="@array/joystick_names" android:title="@string/select_joystick" android:key="joystick" app:useSimpleSummaryProvider="true"></ListPreference>
        <SwitchPreferenceCompat android:key="use sensor" android:title="@string/use_sensor" android:summary="@string/use_sensor_desc"></SwitchPreferenceCompat>
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/pref_sound">
        <ListPreference android:title="@string/sound_chip" android:entryValues="@array/sound_chip_values" android:entries="@array/sound_chip_names" android:key="sound chip" app:useSimpleSummaryProvider="true"></ListPreference>
        <ListPreference android:key="ay stereo" android:entryValues="@array/sound_chip_stereo_values" android:entries="@array/sound_chip_stereo_names" android:title="@string/sound_chip_stereo" app:useSimpleSummaryProvider="true"></ListPreference>
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/pref_peripherals">
        <SwitchPreferenceCompat android:title="@string/auto_play_image" android:summary="@string/auto_play_image_desc" android:key="auto play image"></SwitchPreferenceCompat>
        <ListPreference android:title="@string/save_slot" android:key="save slot" android:entryValues="@array/slot_values" android:entries="@array/slot_names" app:useSimpleSummaryProvider="true"></ListPreference>
        <Preference android:title="@string/save_file" android:summary="@string/save_file_desc" android:key="save file"></Preference>
        <ListPreference android:title="@string/drive" android:key="drive" android:entryValues="@array/drive_values" android:entries="@array/drive_names" app:useSimpleSummaryProvider="true"></ListPreference>
        <Preference android:title="@string/tape" android:key="tape"></Preference>
        <SwitchPreferenceCompat android:title="@string/tape_fast" android:summary="@string/tape_fast_desc" android:key="fast tape"></SwitchPreferenceCompat>
        <SwitchPreferenceCompat android:title="@string/mode_48k" android:key="mode 48k"></SwitchPreferenceCompat>
        <SwitchPreferenceCompat android:title="@string/reset_to_service_rom" android:summary="@string/service_rom_desc" android:key="reset to service rom"></SwitchPreferenceCompat>
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/pref_view">
        <ListPreference android:entries="@array/zoom_names" android:entryValues="@array/zoom_values" android:key="zoom" android:title="@string/zoom" app:useSimpleSummaryProvider="true"></ListPreference>
        <SwitchPreferenceCompat android:title="@string/filtering" android:key="filtering"></SwitchPreferenceCompat>
        <SwitchPreferenceCompat android:title="@string/gigascreen" android:key="gigascreen" android:summary="@string/gigascreen_desc"></SwitchPreferenceCompat>
        <SwitchPreferenceCompat android:title="@string/black_and_white" android:key="black and white"></SwitchPreferenceCompat>
        <ListPreference android:entries="@array/theme_names" android:entryValues="@array/theme_values" android:defaultValue="dark" android:title="@string/theme" android:key="theme" app:useSimpleSummaryProvider="true"></ListPreference>
    </PreferenceCategory>
</PreferenceScreen>
